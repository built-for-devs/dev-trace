# Trace (local) — optional API keys. Copy to .env and fill in what you have.
# Every key is OPTIONAL. Missing keys just skip that depth — nothing breaks.

# --- Free, but strongly recommended (raises GitHub limit 60/hr -> 5000/hr) ---
# Create at: https://github.com/settings/tokens (no scopes needed for public data)
GITHUB_TOKEN=

# --- Freemium (free tier ~25-50 verifications/mo) ---
# https://hunter.io
HUNTER_API_KEY=

# --- Paid, bring your own (the upsell layers) ---
# Tabstack: public web/company enrichment
TABSTACK_API_KEY=
# SixtyFour: completeness backstop (public professional fields only, customer-scoped)
SIXTYFOUR_API_KEY=
